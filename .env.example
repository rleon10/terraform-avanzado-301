# Copia este archivo a .env y rellena tus credenciales del curso.
#   cp .env.example .env   &&   direnv allow
#
# En Codespaces (recomendado): usa "Codespaces secrets" en lugar de .env.
# Si usas .env en Codespaces: direnv allow  O  source .env antes de los scripts.

# --- Credenciales AWS base (solo puerta de entrada; permisos vía rol) ---------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # solo si son temporales (STS)

# --- Región del curso ---------------------------------------------------------
AWS_REGION=us-east-2
AWS_DEFAULT_REGION=us-east-2

# --- Tu identificador de alumno (prefijo de recursos: curso-<usuario>-*) ------
AWS_LAB_USER=david.pestana

# --- Asunción de rol (obligatorio) -------------------------------------------
AWS_ROLE_ARN=arn:aws:iam::800789335147:role/lab-role-curso
AWS_ROLE_SESSION_NAME=tf-curso
# No uses AWS_PROFILE=lab: el CLI no asume el rol solo con esa variable.
# Usa: aws --profile lab …   (los scripts del curso lo hacen automáticamente).

# --- (Opcional) M13 — par de claves SSH en us-east-2 --------------------------
# TF_VAR_key_name=
